<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Scouting Desk: Player Portfolio</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#16131A;--muted:#7C7682;--line:#E5E0E6;--paper:#F2F0F3;
  --card:#FFFFFF;--pitch:#0E5C3E;--grey:#C2B8BC;
  --wc-bg:#003380;--wc-gold:#FFC300;--wc-orange:#FF6B35;
}
*{box-sizing:border-box;}
html,body{margin:0;}
body{background:var(--paper);color:var(--ink);font-family:"Inter",system-ui,sans-serif;line-height:1.55;-webkit-font-smoothing:antialiased;}
.wrap{max-width:1080px;margin:0 auto;padding:0 16px;}
.hidden{display:none !important;}
button{font-family:inherit;cursor:pointer;}

/* ── MASTHEAD ── */
.mast{padding:36px 0 22px;border-bottom:2px solid var(--ink);margin-bottom:26px;}
.mast .eyebrow{font-family:"Oswald",sans-serif;text-transform:uppercase;letter-spacing:4px;font-size:12px;color:var(--pitch);margin:0 0 6px;}
.mast h1{font-family:"Oswald",sans-serif;font-weight:700;text-transform:uppercase;letter-spacing:1px;font-size:clamp(28px,5vw,44px);margin:0;line-height:1;}
.mast .tag{color:var(--muted);font-size:15px;margin:10px 0 0;}
.stats{display:flex;gap:26px;flex-wrap:wrap;margin-top:16px;}
.stat .n{font-family:"IBM Plex Mono",monospace;font-weight:600;font-size:22px;}
.stat .l{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);}

/* ── FILTERS ── */
.filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:22px;}
.filters button{background:var(--card);border:1px solid var(--line);border-radius:30px;padding:7px 15px;font-size:13px;color:var(--ink);transition:.15s;white-space:nowrap;}
.filters button:hover{border-color:var(--ink);}
.filters button.on{background:var(--ink);color:#fff;border-color:var(--ink);}
.filters button.wc-btn{background:var(--wc-bg);color:var(--wc-gold);border-color:var(--wc-bg);font-weight:700;letter-spacing:.5px;}
.filters button.wc-btn:hover{background:#004BB8;}
.filters button.back-btn{background:#F5F0F2;border-color:var(--line);font-weight:600;}

/* ── BOARD ── */
.board{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:18px;padding-bottom:50px;}

/* ── PLAYER CARDS ── */
.pcard{background:var(--card);border:1px solid var(--line);border-radius:8px;overflow:hidden;text-align:left;padding:0;transition:.18s;display:flex;flex-direction:column;}
.pcard:hover{transform:translateY(-3px);box-shadow:0 16px 34px -22px rgba(20,8,16,.5);border-color:var(--c,#999);}
.pcard .top{padding:16px 18px;color:#fff;position:relative;overflow:hidden;}
.pcard .ghost{position:absolute;right:-6px;top:-26px;font-family:"Oswald",sans-serif;font-weight:700;font-size:110px;line-height:1;color:rgba(0,0,0,.15);}
.pcard .club{position:relative;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;opacity:.85;}
.pcard .nm{position:relative;font-family:"Oswald",sans-serif;font-weight:600;font-size:23px;line-height:1.05;text-transform:uppercase;margin-top:3px;}
.pcard .sub{position:relative;font-size:12.5px;opacity:.9;margin-top:6px;}
.pcard .body{padding:14px 18px 16px;flex:1;display:flex;flex-direction:column;gap:12px;}
.pcard .vt{font-size:13.5px;color:#34303a;line-height:1.45;}
.pcard .badge{align-self:flex-start;margin-top:auto;font-family:"IBM Plex Mono",monospace;font-size:11.5px;font-weight:600;background:#F1EEF2;border-radius:5px;padding:5px 9px;}
.pcard .badge b{color:var(--c,#333);}
.pcard .feat-star{position:absolute;top:12px;right:12px;background:var(--wc-gold);color:#1A1200;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:bold;line-height:1;}

/* ── ADD TILE ── */
.addtile{border:1.5px dashed var(--line);border-radius:8px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:30px 18px;color:var(--muted);min-height:200px;}
.addtile .plus{font-family:"Oswald",sans-serif;font-size:34px;color:var(--line);}
.addtile p{margin:10px 0 0;font-size:13px;max-width:200px;}

/* ── WORLD CUP ── */
.wc-view{padding-bottom:50px;}
.wc-banner{position:relative;background:var(--wc-bg);overflow:hidden;border-radius:8px;margin-bottom:22px;padding:30px 24px 24px;color:#fff;}
.wc-banner::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:linear-gradient(90deg,#FFC300 0%,#FF6B35 50%,#FFC300 100%);}
.wc-banner::after{content:'';position:absolute;top:-60px;right:-60px;width:240px;height:240px;border-radius:50%;background:radial-gradient(circle,rgba(255,195,0,.18) 0%,transparent 70%);pointer-events:none;}
.wc-deco{position:absolute;bottom:-40px;left:20%;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(255,107,53,.14) 0%,transparent 70%);pointer-events:none;}
.wc-ghost{position:absolute;right:18px;bottom:-18px;font-family:"Oswald",sans-serif;font-weight:700;font-size:110px;line-height:1;color:rgba(255,195,0,.10);letter-spacing:-4px;pointer-events:none;user-select:none;}
.wc-eyebrow{font-family:"Oswald",sans-serif;font-weight:500;letter-spacing:4px;font-size:11px;color:var(--wc-gold);text-transform:uppercase;margin:0 0 8px;position:relative;}
.wc-title{font-family:"Oswald",sans-serif;font-weight:700;font-size:clamp(34px,7vw,56px);line-height:.95;text-transform:uppercase;letter-spacing:.5px;color:#fff;margin:0;position:relative;}
.wc-title span{color:var(--wc-gold);}
.wc-sub{font-size:13.5px;color:rgba(255,255,255,.75);margin-top:12px;position:relative;}
.wc-meta{display:flex;gap:20px;flex-wrap:wrap;margin-top:16px;position:relative;}
.wc-stat .n{font-family:"IBM Plex Mono",monospace;font-weight:600;font-size:20px;color:var(--wc-gold);}
.wc-stat .l{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.6);}
.wc-back{background:none;border:1px solid rgba(255,255,255,.25);border-radius:30px;padding:8px 16px;font-size:13px;color:rgba(255,255,255,.8);margin-top:16px;display:inline-block;position:relative;transition:.15s;}
.wc-back:hover{border-color:var(--wc-gold);color:var(--wc-gold);}

/* ── COMPARE OVERLAY ── */
.compare-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(22,19,26,.55);z-index:100;display:flex;align-items:center;justify-content:center;padding:20px;}
.compare-panel{background:#fff;border-radius:10px;width:100%;max-width:480px;max-height:80vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 24px 60px -20px rgba(0,0,0,.5);}
.compare-panel-head{padding:18px 20px 14px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;}
.compare-panel-head h3{font-family:"Oswald",sans-serif;font-size:20px;text-transform:uppercase;letter-spacing:.5px;margin:0;}
.compare-panel-head button{background:none;border:none;font-size:20px;color:var(--muted);cursor:pointer;padding:4px 8px;}
.compare-search-wrap{padding:14px 16px 10px;}
.compare-search-input{width:100%;padding:10px 14px;border:1px solid var(--line);border-radius:30px;font-size:14px;font-family:"Inter",sans-serif;outline:none;}
.compare-results{overflow-y:auto;padding:0 10px 12px;}
.compare-result-item{display:flex;align-items:center;gap:12px;padding:10px;border-radius:6px;cursor:pointer;transition:.12s;}
.compare-result-item:hover{background:#F5F2F6;}
.compare-result-dot{width:32px;height:32px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:"Oswald",sans-serif;font-size:11px;font-weight:700;color:#fff;}
.compare-result-name{font-weight:600;font-size:14px;}
.compare-result-sub{font-size:12px;color:var(--muted);}
.compare-empty{padding:20px;text-align:center;color:var(--muted);font-size:13px;}

/* ── REPORT DETAIL ── */
.report-view{padding:18px 0 60px;}
.report-view-actions{display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap;}
.backbtn{background:none;border:1px solid var(--line);border-radius:30px;padding:8px 16px;font-size:13px;color:var(--ink);}
.backbtn:hover{border-color:var(--ink);}
.report{background:var(--card);border:1px solid var(--line);border-radius:6px;overflow:hidden;box-shadow:0 18px 50px -30px rgba(40,10,20,.4);}
.np{position:relative;background:var(--claret);color:#fff;padding:20px 22px;overflow:hidden;border-radius:5px 5px 0 0;}
.np-ghost{position:absolute;right:6px;top:-38px;font-family:"Oswald",sans-serif;font-weight:700;font-size:150px;line-height:1;color:rgba(255,255,255,.08);letter-spacing:-8px;pointer-events:none;}
.eb{text-transform:uppercase;letter-spacing:2.5px;font-size:8px;color:var(--blue);margin-bottom:4px;}
.np h2{font-family:"Oswald",sans-serif;font-weight:700;font-size:clamp(30px,5.5vw,50px);line-height:.98;margin:0;text-transform:uppercase;letter-spacing:.5px;}
.np-meta{display:flex;flex-wrap:wrap;gap:5px 16px;margin-top:14px;font-size:13px;color:rgba(255,255,255,.86);}
.np-meta b{color:#fff;font-weight:600;}
.np-meta .dot{color:var(--blue);}
.np-right{display:flex;flex-direction:column;gap:13px;align-items:flex-end;justify-content:center;}
.chips{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-start;margin-top:14px;}
.chip{background:rgba(255,255,255,.10);border:1px solid rgba(255,255,255,.16);border-radius:4px;padding:6px 11px;}
.chip .k{display:block;font-size:9.5px;letter-spacing:1.5px;text-transform:uppercase;color:var(--blue);}
.chip .v{display:block;font-family:"IBM Plex Mono",monospace;font-weight:600;font-size:14px;color:#fff;margin-top:2px;}
.pitch-wrap{width:250px;}
.pitch-cap{font-size:8px;letter-spacing:1.2px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-top:3px;}
.np-grid{position:relative;display:flex;gap:26px;justify-content:space-between;flex-wrap:wrap;}
.np-left{min-width:240px;flex:1;}
.verdict-block{background:#fff;border:1px solid #E7DFE2;border-top:none;border-left:4px solid var(--claret);padding:14px 20px;}
.verdict-block .eb2{text-transform:uppercase;letter-spacing:2px;font-size:8px;color:var(--claret);margin-bottom:3px;}
.verdict-block p{margin:2px 0 0;font-size:15px;font-weight:600;line-height:1.45;}
.block{background:#fff;border:1px solid #E7DFE2;border-top:none;padding:12px 20px;}
.eb2{text-transform:uppercase;letter-spacing:2px;font-size:8px;color:var(--claret);margin-bottom:3px;}
.bt{font-family:"Oswald",sans-serif;font-weight:600;text-transform:uppercase;letter-spacing:.5px;font-size:16px;margin-bottom:10px;}
.lede{font-size:13px;color:#34272c;line-height:1.6;}
.legend{display:flex;gap:18px;flex-wrap:wrap;margin:0 0 12px;font-size:11px;color:var(--muted);}
.legend span{display:inline-flex;align-items:center;gap:5px;}
.legend i{width:9px;height:9px;border-radius:2px;display:inline-block;}
.bar{display:grid;grid-template-columns:170px 1fr 48px;align-items:center;gap:12px;margin:8px 0;}
.bar-label{font-size:12px;font-weight:500;}
.bar-label small{display:block;font-family:"IBM Plex Mono",monospace;color:var(--muted);font-size:10px;margin-top:1px;}
.track{background:#EFEAEC;border-radius:3px;height:13px;overflow:hidden;}
.fill{height:100%;width:0;border-radius:3px;transition:width .9s cubic-bezier(.22,1,.36,1);}
.pct{font-family:"IBM Plex Mono",monospace;font-weight:600;font-size:16px;text-align:right;}
.pct small{font-size:9px;color:var(--muted);}
.rates{display:flex;gap:26px;flex-wrap:wrap;margin-top:10px;}
.rate{flex:1;min-width:160px;}
.rate-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:5px;}
.rate-top .lab{font-size:12px;font-weight:500;}
.rate-top .num{font-family:"IBM Plex Mono",monospace;font-weight:600;font-size:16px;}
.rate-track{background:#EFEAEC;border-radius:3px;height:9px;overflow:hidden;}
.rate-fill{height:9px;width:0;border-radius:3px;background:var(--muted);transition:width .9s cubic-bezier(.22,1,.36,1);}
.note{font-size:10px;color:var(--muted);margin-top:10px;}
.cols{display:grid;grid-template-columns:1fr 1fr;gap:26px;}
.col h4{font-family:"Oswald",sans-serif;text-transform:uppercase;letter-spacing:1px;font-size:12px;margin:0 0 8px;}
/* FIXED: these use hard colours so they never vanish against a white background */
.col.s h4{color:#1565C0;}
.col.w h4{color:#822D3A;}
.col ul{list-style:none;margin:0;padding:0;}
.col li{position:relative;padding-left:14px;margin-bottom:8px;font-size:12.5px;line-height:1.5;}
.col.s li:before{content:"+";position:absolute;left:0;color:#1565C0;font-weight:bold;}
.col.w li:before{content:"\2013";position:absolute;left:0;color:#822D3A;font-weight:bold;}
.callout{background:#FBF7F4;border:1px solid #E7DFE2;border-radius:4px;padding:12px 14px;}
.callout p{margin:0;font-size:12px;color:#34272c;line-height:1.6;}
.foot-r{border:1px solid #E7DFE2;border-top:none;border-radius:0 0 6px 6px;background:#FBF9F8;padding:12px 20px;font-size:10px;color:var(--muted);}
.foot-r .method{color:var(--claret);font-weight:600;margin-bottom:8px;font-size:10.5px;}
.foot-r .fr{display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;}
.foot-r b{color:#4a3b40;}

/* ── SUBSCRIBE FORM ── */
.sub-form{background:var(--ink);border-radius:8px;padding:28px 24px;margin:40px 0;color:#fff;}
.sub-form h3{font-family:"Oswald",sans-serif;font-size:22px;text-transform:uppercase;letter-spacing:.5px;margin:0 0 6px;}
.sub-form p{font-size:13px;color:rgba(255,255,255,.65);margin:0 0 20px;}
.sub-inputs{display:flex;gap:10px;flex-wrap:wrap;}
.sub-inputs input{flex:1;min-width:160px;padding:10px 14px;border-radius:6px;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.08);color:#fff;font-size:13px;font-family:"Inter",sans-serif;}
.sub-inputs input::placeholder{color:rgba(255,255,255,.4);}
.sub-inputs button{padding:10px 20px;border-radius:6px;border:none;background:#1CA4DA;color:#fff;font-size:13px;font-weight:600;font-family:"Inter",sans-serif;cursor:pointer;white-space:nowrap;}
.sub-msg{margin-top:10px;font-size:13px;color:rgba(255,255,255,.75);}

/* ── RESPONSIVE ── */
@media(max-width:600px){
  .np,.verdict-block,.block,.foot-r{padding-left:16px;padding-right:16px;}
  .np-ghost{font-size:110px;}
  .bar{grid-template-columns:120px 1fr 44px;gap:8px;}
  .cols{grid-template-columns:1fr;gap:16px;}
  .np-right{align-items:flex-start;}
  .pitch-wrap{width:100%;}
  .wc-banner{border-radius:6px;padding:24px 18px 20px;}
}
@media print{
  body{background:#fff;}
  #boardView,#worldCupView,#compareOverlay,
  .report-view-actions,.sub-form,
  #searchInput,.filters{display:none!important;}
  .report-view{padding:0;}
  .wrap{padding:0;max-width:none;}
  .report{box-shadow:none;border:none;border-radius:0;}
  .block,.verdict-block,.foot-r{break-inside:avoid;}
  .np{border-radius:0;}
  .fill{transition:none;}
}
@media(prefers-reduced-motion:reduce){.fill,.rate-fill,.pcard{transition:none;}}
</style>
</head>
<body>
<div class="wrap">

  <!-- ═══ COMPARE OVERLAY ════════════════════════════════════════ -->
  <div id="compareOverlay" class="compare-overlay hidden" onclick="closeCompareSearch(event)">
    <div class="compare-panel" onclick="event.stopPropagation()">
      <div class="compare-panel-head">
        <h3>Compare with</h3>
        <button onclick="closeCompareSearch()">&#10005;</button>
      </div>
      <div class="compare-search-wrap">
        <input id="compareSearchInput" class="compare-search-input"
          type="text" placeholder="Search players, clubs, positions..."
          oninput="filterCompareList(this.value)">
      </div>
      <div class="compare-results" id="compareResults"></div>
    </div>
  </div>

  <!-- ═══ BOARD VIEW ══════════════════════════════════════════════ -->
  <div id="boardView">
    <header class="mast">
      <p class="eyebrow" id="siteEyebrow"></p>
      <h1 id="siteName"></h1>
      <p class="tag" id="siteTag"></p>
      <div class="stats" id="siteStats"></div>
    </header>
    <div style="margin-bottom:14px;">
      <input id="searchInput" type="text"
        placeholder="Search players, clubs, leagues..."
        oninput="handleSearch(this.value)"
        style="width:100%;padding:10px 16px;border:1px solid #E5E0E6;
               border-radius:30px;font-size:14px;font-family:'Inter',sans-serif;
               background:#fff;outline:none;color:#16131A;">
    </div>
    <div class="filters" id="mainFilters"></div>
    <div class="filters hidden" id="posFilters"></div>
    <div class="board" id="board"></div>
  </div>

  <!-- ═══ WORLD CUP VIEW ══════════════════════════════════════════ -->
  <div id="worldCupView" class="hidden wc-view">
    <div class="wc-banner">
      <div class="wc-deco"></div>
      <div class="wc-ghost">26</div>
      <p class="wc-eyebrow">The Scouting Desk</p>
      <h2 class="wc-title">World Cup <span>2026</span></h2>
      <p class="wc-sub">Tournament player profiles and recruitment analysis</p>
      <div class="wc-meta" id="wcMeta"></div>
      <button class="wc-back" onclick="showBoard()">&#8592; Back to Main Board</button>
    </div>
    <div class="board" id="wcBoard"></div>
  </div>

  <!-- ═══ REPORT VIEW ══════════════════════════════════════════════ -->
  <div id="reportView" class="report-view hidden">
    <div class="report-view-actions">
      <button class="backbtn" id="backBtn" onclick="goBack()">&#8592; Back</button>
      <button class="backbtn" onclick="openCompareSearch()"
        style="background:#16131A;color:#fff;border-color:#16131A;">&#8644; Compare</button>
      <button class="backbtn export-btn" onclick="window.print()"
        style="background:#444;color:#fff;border-color:#444;">&#8595; Export PDF</button>
    </div>
    <div class="report" id="report"></div>
  </div>

  <!-- ═══ SUBSCRIBE FORM ══════════════════════════════════════════ -->
  <div class="sub-form" id="subFormBlock">
    <h3>Stay in the loop</h3>
    <p>Get an email when a new scouting report drops. No spam, unsubscribe anytime.</p>
    <div class="sub-inputs" id="subForm">
      <input id="subName" type="text" placeholder="Your name (optional)">
      <input id="subEmail" type="email" placeholder="Email address">
      <button onclick="subscribe()">Subscribe</button>
    </div>
    <div class="sub-msg" id="subMsg"></div>
  </div>

</div><!-- /.wrap -->

<script>
/* ══ SUPABASE — add your keys here for the subscribe form ══ */
const HUB_SUPABASE_URL = 'YOUR_SUPABASE_PROJECT_URL';
const HUB_SUPABASE_KEY = 'YOUR_SUPABASE_ANON_KEY';
let hubSb = null;
try { hubSb = supabase.createClient(HUB_SUPABASE_URL, HUB_SUPABASE_KEY); } catch(e){}

/* ══ SITE BRANDING ══ */
const SITE = {
  eyebrow: 'Independent Scouting',
  name:    'The Scouting Desk',
  tagline: 'Player analysis, profiles and recruitment notes.',
  author:  'Ben Martin',
};

/* ══ REPORTS ══ */
/* __REPORTS_START__ */
const REPORTS = [
{
  id:'diouf', featured:false, worldCup:false, dateAdded:null, image:null,
  name:'El Hadji Malick Diouf', club:'West Ham United', league:'Premier League',
  posGroup:'Full-back', number:12, positions:['LB','LWB'],
  theme:{claret:'#7A263A',blue:'#1CA4DA'},
  meta:{Position:'Left-back / Left wing-back',Age:'21',Foot:'Left',Nationality:'Senegal',Born:'28 Dec 2004'},
  chips:[{k:'Market value',v:'\u20ac28.0m'},{k:'Fee',v:'\u20ac22m + \u20ac4m'},{k:'Contract',v:'to 2030'}],
  verdict:'A high-ceiling attacking left-back whose elite ball progression and final-third output have already translated to the Premier League at just 21. His defensive duelling is where the work remains, and it is also where the risk sits.',
  role:'A modern left-back and wing-back in the overlapping, ball-carrying mould. He lives high and wide, takes the ball in advanced areas and drives at defenders rather than sitting in to anchor the back line. Left-footed and athletic, he is at his most dangerous as a creator down the flank. He models his game on Marcelo, and the numbers back that up.',
  percentiles:[
    {label:'Touches in att. box',per90:'3.31',pct:96},
    {label:'Prog. passes received',per90:'8.43',pct:95},
    {label:'Progressive passes',per90:'6.77',pct:95},
    {label:'Progressive carries',per90:'3.31',pct:90},
    {label:'Successful take-ons',per90:'1.51',pct:93},
  ],
  percentileNote:"Per 90, measured against full-back peers, from Diouf's pre-move sample (domestic league plus UEFA competition). Read it as a strong signal rather than a final grade.",
  rates:[{label:'Aerial duels won',pct:66},{label:'Ground duels won',pct:50}],
