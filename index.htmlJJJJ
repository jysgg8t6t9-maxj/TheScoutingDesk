},
];
/* __REPORTS_END__ */

/* ══ STATE ══ */
let activeFilter    = 'All';
let filterMode      = 'main';
let reportOrigin    = 'board';
let currentReportId = null;
let searchQuery     = '';
let compareSourceId = null;

/* ══ HELPERS ══ */
const esc = s => String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
const topMetric = p => [...p.percentiles].sort((a,b)=>b.pct-a.pct)[0];
const tier = pct => pct>=80?'#1565C0':pct>=50?'#822D3A':'#A0968C';

const Z={GK:[6,50,24,22],CB:[6,44,50,34],RB:[6,82,66,34],LB:[6,6,66,34],RWB:[6,82,114,30],LWB:[6,6,114,30],DM:[54,38,46,46],CM:[88,34,54,54],AM:[126,36,50,50],RW:[114,88,72,28],LW:[114,6,72,28],ST:[142,40,42,42]};
function pitchSVG(pos){
  const rects=pos.map(p=>Z[p]).filter(Boolean).map(([x,y,w,h])=>`<rect x="${x}" y="${y}" width="${w}" height="${h}" rx="3" fill="#fff" fill-opacity="0.5"/>`).join('');
  return `<svg viewBox="0 0 188 120" width="100%"><rect x="1" y="1" width="186" height="118" rx="4" fill="rgba(255,255,255,.04)" stroke="rgba(255,255,255,.35)"/><line x1="94" y1="2" x2="94" y2="118" stroke="rgba(255,255,255,.35)"/><circle cx="94" cy="60" r="15" fill="none" stroke="rgba(255,255,255,.35)"/><rect x="2" y="36" width="24" height="48" fill="none" stroke="rgba(255,255,255,.35)"/><rect x="162" y="36" width="24" height="48" fill="none" stroke="rgba(255,255,255,.35)"/>${rects}<text x="182" y="114" text-anchor="end" fill="rgba(255,255,255,.5)" font-size="8">ATTACKING &#8594;</text></svg>`;
}

function radarChart(metrics){
  const N=metrics.length;
  if(N<3)return '';
  const cx=110,cy=115,R=78;
  const angle=i=>-Math.PI/2+(i/N)*2*Math.PI;
  const pt=(r,i)=>{const a=angle(i);return{x:cx+r*Math.cos(a),y:cy+r*Math.sin(a)};};
  const ps=(r,i)=>{const p=pt(r,i);return p.x.toFixed(1)+','+p.y.toFixed(1);};
  const ptList=r=>metrics.map((_,i)=>ps(r,i)).join(' ');
  const rings=[25,50,75,100].map(v=>`<polygon points="${ptList((v/100)*R)}" fill="none" stroke="#E5E0E6" stroke-width="0.8"/>`).join('');
  const spokes=metrics.map((_,i)=>{const p=pt(R,i);return `<line x1="${cx}" y1="${cy}" x2="${p.x.toFixed(1)}" y2="${p.y.toFixed(1)}" stroke="#E5E0E6" stroke-width="0.8"/>`;}).join('');
  const dataPts=metrics.map((m,i)=>ps((m.pct/100)*R,i)).join(' ');
  const dots=metrics.map((m,i)=>{const p=pt((m.pct/100)*R,i);return `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="3.5" fill="#822D3A"/>`;}).join('');
  const labels=metrics.map((m,i)=>{
    const p=pt(R+20,i);
    const anchor=p.x<cx-5?'end':p.x>cx+5?'start':'middle';
    const lbl=m.label.length>14?m.label.substring(0,13)+'.':m.label;
    return `<text x="${p.x.toFixed(1)}" y="${(p.y+3).toFixed(1)}" text-anchor="${anchor}" font-size="8.5" fill="#7C7682" font-family="Inter,sans-serif">${lbl}</text><text x="${p.x.toFixed(1)}" y="${(p.y+12).toFixed(1)}" text-anchor="${anchor}" font-size="8" fill="#1565C0" font-family="monospace" font-weight="bold">${m.pct}</text>`;
  }).join('');
  return `<svg viewBox="0 0 220 230" width="220" height="230" style="display:block;margin:0 auto;">${rings}${spokes}<polygon points="${dataPts}" fill="#1565C0" fill-opacity="0.12" stroke="#1565C0" stroke-width="1.8"/>${dots}${labels}<text x="${cx}" y="${cy}" text-anchor="middle" font-size="9" fill="#C2B8BC" font-family="monospace">Percentile</text></svg>`;
}

/* ══ MASTHEAD ══ */
function renderMast(){
  document.getElementById('siteEyebrow').textContent=SITE.eyebrow;
  document.getElementById('siteName').textContent=SITE.name;
  document.getElementById('siteTag').textContent=SITE.tagline;
  const leagues=new Set(REPORTS.map(p=>p.league));
  const s=[[REPORTS.length,'Players scouted'],[leagues.size,'Leagues covered'],[SITE.author,'Analyst']];
  document.getElementById('siteStats').innerHTML=s.map(([n,l])=>`<div class="stat"><div class="n">${esc(String(n))}</div><div class="l">${esc(l)}</div></div>`).join('');
}

/* ══ FILTERS ══ */
function getPositionCounts(){const c={};REPORTS.forEach(p=>{c[p.posGroup]=(c[p.posGroup]||0)+1;});return c;}

function renderMainFilters(){
  const onPos=!['All','Featured'].includes(activeFilter)&&filterMode==='main'?activeFilter:null;
  document.getElementById('mainFilters').innerHTML=[
    `<button class="${activeFilter==='All'?'on':''}" onclick="setFilter('All')">All</button>`,
    `<button class="${activeFilter==='Featured'?'on':''}" onclick="setFilter('Featured')">Featured</button>`,
    `<button class="${onPos?'on':''}" onclick="openPositionsMenu()">Positions ${onPos?'('+onPos+')':''} &#9656;</button>`,
    `<button class="wc-btn" onclick="showWorldCup()">World Cup 2026</button>`,
  ].join('');
}

function renderPosFilters(){
  const counts=getPositionCounts();
  const posButtons=Object.entries(counts).sort((a,b)=>b[1]-a[1]).map(([pos,n])=>`<button class="${activeFilter===pos?'on':''}" onclick="setPosFilter('${esc(pos)}')">${esc(pos)} (${n})</button>`).join('');
  document.getElementById('posFilters').innerHTML=`<button class="back-btn" onclick="closePositionsMenu()">&#8592; Back</button>${posButtons}`;
}

function openPositionsMenu(){filterMode='positions';document.getElementById('mainFilters').classList.add('hidden');document.getElementById('posFilters').classList.remove('hidden');renderPosFilters();}
function closePositionsMenu(){filterMode='main';document.getElementById('posFilters').classList.add('hidden');document.getElementById('mainFilters').classList.remove('hidden');renderMainFilters();}
function setPosFilter(pos){activeFilter=pos;closePositionsMenu();renderBoard();}
function setFilter(f){activeFilter=f;filterMode='main';document.getElementById('posFilters').classList.add('hidden');document.getElementById('mainFilters').classList.remove('hidden');renderMainFilters();renderBoard();}

/* ══ BOARD ══ */
function renderBoard(){
  let list;
  if(activeFilter==='All'){list=REPORTS;}
  else if(activeFilter==='Featured'){list=REPORTS.filter(p=>p.featured);}
  else{list=REPORTS.filter(p=>p.posGroup===activeFilter);}
  if(searchQuery){list=list.filter(p=>p.name.toLowerCase().includes(searchQuery)||p.club.toLowerCase().includes(searchQuery)||p.posGroup.toLowerCase().includes(searchQuery)||(p.meta.Nationality&&p.meta.Nationality.toLowerCase().includes(searchQuery)));}
  const cards=list.map(p=>{
    const t=topMetric(p);
    const star=p.featured?`<div class="feat-star">&#9733;</div>`:'';
    return `<button class="pcard" style="--c:${p.theme.claret}" onclick="showReport('${p.id}','board')">
      <div class="top" style="background:${p.theme.claret}">
        ${star}<span class="ghost">${p.number||''}</span>
        <span class="club">${esc(p.club)}</span>
        <div class="nm">${esc(p.name)}</div>
        <div class="sub">${esc(p.meta.Position)} &middot; ${esc(p.meta.Age)}</div>
      </div>
      <div class="body">
        <div class="vt">${esc(p.verdict.split('.')[0])}.</div>
        <div class="badge"><b>${t.pct}th</b> pct &middot; ${esc(t.label)}</div>
      </div>
    </button>`;
  }).join('');
  const empty=list.length===0?`<div class="addtile"><div class="plus">&#9679;</div><p>No reports in this section yet.</p></div>`:'';
  const addTile=activeFilter==='All'?`<div class="addtile"><div class="plus">+</div><p>Your next report goes here.</p></div>`:'';
  document.getElementById('board').innerHTML=cards+empty+addTile;
}

/* ══ WORLD CUP BOARD ══ */
function renderWorldCupBoard(){
  const wc=REPORTS.filter(p=>p.worldCup).sort((a,b)=>{
    if(!a.dateAdded&&!b.dateAdded)return 0;if(!a.dateAdded)return 1;if(!b.dateAdded)return -1;
    return new Date(b.dateAdded)-new Date(a.dateAdded);
  });
  const nations=new Set(wc.map(p=>p.meta.Nationality));
  document.getElementById('wcMeta').innerHTML=[[wc.length,'Reports'],[nations.size,'Nations']].map(([n,l])=>`<div class="wc-stat"><div class="n">${n}</div><div class="l">${esc(l)}</div></div>`).join('');
  const cards=wc.map(p=>{
    const t=topMetric(p);
    const dl=p.dateAdded?new Date(p.dateAdded).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}):'';
    return `<button class="pcard" style="--c:${p.theme.claret}" onclick="showReport('${p.id}','worldcup')">
      <div class="top" style="background:${p.theme.claret}">
        <span class="ghost">${p.number||''}</span>
        <span class="club">${esc(p.club)} &middot; ${esc(p.meta.Nationality)}</span>
        <div class="nm">${esc(p.name)}</div>
        <div class="sub">${esc(p.meta.Position)} &middot; Age ${esc(p.meta.Age)}</div>
      </div>
      <div class="body">
        <div class="vt">${esc(p.verdict.split('.')[0])}.</div>
        <div class="badge"><b>${t.pct}th</b> pct &middot; ${esc(t.label)}</div>
        ${dl?`<div style="font-size:10.5px;color:var(--muted);margin-top:2px;">Added ${esc(dl)}</div>`:''}
      </div>
    </button>`;
  }).join('');
  const empty=wc.length===0?`<div class="addtile"><div class="plus">&#9733;</div><p>No World Cup reports yet. Set worldCup: true to add.</p></div>`:'';
  document.getElementById('wcBoard').innerHTML=cards+empty;
}

/* ══ REPORT ══ */
function renderReport(p){
  const el=document.getElementById('report');
  el.style.setProperty('--claret',p.theme.claret);
  el.style.setProperty('--blue',p.theme.blue);
  const meta=Object.entries(p.meta).map(([k,v],i)=>`${i?'<span class="dot">&middot;</span>':''}<span>${esc(k)} <b>${esc(v)}</b></span>`).join(' ');
  const chips=p.chips.map(c=>`<div class="chip"><span class="k">${esc(c.k)}</span><span class="v">${esc(c.v)}</span></div>`).join('');
  const bars=p.percentiles.map(b=>`<div class="bar"><div class="bar-label">${esc(b.label)}<small>${esc(b.per90)} per 90</small></div><div class="track"><div class="fill" data-w="${b.pct}" style="background:${tier(b.pct)}"></div></div><div class="pct">${b.pct}<small>th</small></div></div>`).join('');
  const rateHTML=p.rates&&p.rates.length?`<h3 class="bt" style="font-size:13px;margin-top:14px;">Duel success rate</h3><div class="rates">${p.rates.map(r=>`<div class="rate"><div class="rate-top"><span class="lab">${esc(r.label)}</span><span class="num">${r.pct}%</span></div><div class="rate-track"><div class="rate-fill" data-w="${r.pct}"></div></div></div>`).join('')}</div>`:'';
  const listBlock=(cls,title,items)=>`<div class="col ${cls}"><h4>${esc(title)}</h4><ul>${items.map(i=>`<li>${esc(i)}</li>`).join('')}</ul></div>`;
  el.innerHTML=`
    <div class="np">
      <div class="np-ghost">${p.number||''}</div>
      <div class="np-grid">
        <div class="np-left">
          <p class="eb">Scouting Report &middot; ${esc(p.club)}</p>
          <h2>${esc(p.name)}</h2>
          <div class="np-meta">${meta}</div>
          <div class="chips">${chips}</div>
        </div>
        <div class="np-right">
          <div class="pitch-wrap">${pitchSVG(p.positions)}<div class="pitch-cap">${p.positions.join(' / ')} zone</div></div>
        </div>
      </div>
    </div>
    <div class="verdict-block"><div class="eb2">Scout verdict</div><p>${esc(p.verdict)}</p></div>
    <div class="block"><div class="eb2">Profile and role</div><p class="lede">${esc(p.role)}</p></div>
    <div class="block">
      <div class="eb2">Statistical profile</div>
      <div style="display:flex;gap:20px;flex-wrap:wrap;align-items:flex-start;margin-bottom:16px;">
        <div style="flex:0 0 220px;">${radarChart(p.percentiles)}</div>
        <div style="flex:1;min-width:200px;">
          <h3 class="bt">Percentile rank (per 90, vs peers)</h3>
          <div class="legend">
            <span><i style="background:#1565C0"></i>Elite (&ge;80th)</span>
            <span><i style="background:#822D3A"></i>Solid (50&ndash;79th)</span>
            <span><i style="background:#A0968C"></i>Work-on (&lt;50th)</span>
          </div>
          ${bars}${rateHTML}
          <p class="note">${esc(p.percentileNote)}</p>
        </div>
      </div>
    </div>
    <div class="block"><div class="cols">${listBlock('s','Strengths',p.strengths)}${listBlock('w','Development areas',p.weaknesses)}</div></div>
    <div class="block"><div class="callout"><div class="eb2">Context</div><h3 class="bt" style="font-size:13px;">${esc(p.callout.title)}</h3><p>${esc(p.callout.body)}</p></div></div>
    <div class="block"><div class="eb2">Outlook</div><h3 class="bt" style="font-size:13px;">${esc(p.projection.title)}</h3><p class="lede">${esc(p.projection.body)}</p></div>
    <div class="foot-r">
      <p class="method">Method: data narrows the search and the eye decides. Percentiles flag where to look; judgement weighs level, age and role.</p>
      <div class="fr">
        <span><b>Sources:</b> ${p.sources.map(esc).join(' &middot; ')}</span>
        <span><b>Compiled:</b> ${esc(p.generated)}</span>
      </div>
      <button onclick="copyLink('${p.id}')" style="background:none;border:1px solid #E7DFE2;border-radius:20px;padding:5px 12px;font-size:11px;color:var(--muted);cursor:pointer;margin-top:8px;">Copy report link</button>
    </div>`;
  requestAnimationFrame(()=>requestAnimationFrame(()=>{el.querySelectorAll('.fill,.rate-fill').forEach(f=>f.style.width=f.dataset.w+'%');}));
}

/* ══ NAVIGATION ══ */
function showReport(id,origin){
  const p=REPORTS.find(r=>r.id===id);
  if(!p)return;
  currentReportId=id;
  reportOrigin=origin||'board';
  document.getElementById('backBtn').textContent=origin==='worldcup'?'\u2190 Back to World Cup':'\u2190 Back to Board';
  renderReport(p);
  document.getElementById('boardView').classList.add('hidden');
  document.getElementById('worldCupView').classList.add('hidden');
  document.getElementById('reportView').classList.remove('hidden');
  history.pushState(null,'','#'+id);
  window.scrollTo(0,0);
}
function goBack(){
  history.pushState(null,'',window.location.pathname);
  document.getElementById('reportView').classList.add('hidden');
  if(reportOrigin==='worldcup')showWorldCup(); else showBoard();
  window.scrollTo(0,0);
}
function showWorldCup(){
  document.getElementById('boardView').classList.add('hidden');
  document.getElementById('reportView').classList.add('hidden');
  document.getElementById('worldCupView').classList.remove('hidden');
  renderWorldCupBoard();window.scrollTo(0,0);
}
function showBoard(){
  document.getElementById('worldCupView').classList.add('hidden');
  document.getElementById('reportView').classList.add('hidden');
  document.getElementById('boardView').classList.remove('hidden');
  window.scrollTo(0,0);
}

/* ══ COMPARE ══ */
function openCompareSearch(){
  filterCompareList('');
  document.getElementById('compareSearchInput').value='';
  document.getElementById('compareOverlay').classList.remove('hidden');
  setTimeout(()=>document.getElementById('compareSearchInput').focus(),80);
}
function closeCompareSearch(e){
  if(e&&e.target!==document.getElementById('compareOverlay'))return;
  document.getElementById('compareOverlay').classList.add('hidden');
}
function filterCompareList(query){
  const q=query.toLowerCase().trim();
  const pool=REPORTS.filter(r=>r.id!==currentReportId);
  const results=q?pool.filter(r=>r.name.toLowerCase().includes(q)||r.club.toLowerCase().includes(q)||r.posGroup.toLowerCase().includes(q)):pool;
  const el=document.getElementById('compareResults');
  if(!results.length){el.innerHTML=`<div class="compare-empty">No players found.</div>`;return;}
  el.innerHTML=results.map(p=>`<div class="compare-result-item" onclick="runComparison('${currentReportId}','${p.id}')"><div class="compare-result-dot" style="background:${p.theme.claret}">${p.number||''}</div><div><div class="compare-result-name">${esc(p.name)}</div><div class="compare-result-sub">${esc(p.club)} &middot; ${esc(p.posGroup)}</div></div></div>`).join('');
}
function runComparison(id1,id2){
  document.getElementById('compareOverlay').classList.add('hidden');
  const p1=REPORTS.find(r=>r.id===id1),p2=REPORTS.find(r=>r.id===id2);
  if(!p1||!p2)return;
  function getMet(p){
    if(p.universalMetrics){const L={goalInvolvement:'Goal Involvement',progressiveActions:'Progressive Actions',duelWins:'Duels Won',xGxA:'xG + xA',shots:'Shots',distance:'Distance'};return Object.entries(p.universalMetrics).filter(([,v])=>v&&v.pct>0).map(([k,v])=>({label:L[k]||k,per90:v.value,pct:v.pct}));}
    return p.percentiles;
  }
  const m1=getMet(p1),m2=getMet(p2);
  const uniMode=p1.universalMetrics&&p2.universalMetrics;
  function col(p,metrics){
    const bars=metrics.map(m=>`<div style="margin:10px 0;"><div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;"><span style="font-weight:600;">${esc(m.label)}</span><span style="font-family:monospace;font-weight:700;color:#1565C0;">${m.pct}th</span></div><div style="background:#EFEAEC;border-radius:3px;height:12px;overflow:hidden;"><div style="width:${m.pct}%;height:12px;border-radius:3px;background:${tier(m.pct)};"></div></div><div style="font-size:10px;color:#9E9E9E;margin-top:2px;">${m.per90} per 90</div></div>`).join('');
    return `<div style="flex:1;min-width:260px;background:#fff;border-radius:8px;padding:18px;border:1px solid #E5E0E6;"><div style="background:${p.theme.claret};color:#fff;padding:12px 16px;border-radius:6px;margin-bottom:16px;"><div style="font-size:10px;letter-spacing:1.5px;text-transform:uppercase;opacity:.8;">${esc(p.club)}</div><div style="font-family:'Oswald',sans-serif;font-size:22px;font-weight:700;text-transform:uppercase;line-height:1.1;">${esc(p.name)}</div><div style="font-size:11px;opacity:.85;margin-top:4px;">${esc(p.meta.Position)} &middot; Age ${esc(p.meta.Age)}</div></div>${bars}<button onclick="showReport('${p.id}','board')" style="width:100%;margin-top:12px;padding:9px;background:${p.theme.claret};color:#fff;border:none;border-radius:6px;font-size:13px;cursor:pointer;">Open Full Report</button></div>`;
  }
  document.getElementById('report').innerHTML=`<div style="padding:20px 20px 28px;"><div style="margin-bottom:18px;"><div style="font-family:'Oswald',sans-serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#7C7682;margin-bottom:4px;">Side by side</div><h2 style="font-family:'Oswald',sans-serif;font-size:30px;text-transform:uppercase;margin:0;">Comparison</h2><p style="color:#7C7682;font-size:13px;margin:6px 0 0;">${uniMode?'Universal metrics — standardised across positions.':'Position-specific percentile ranks. All values are 0-100.'}</p></div><div style="display:flex;gap:16px;flex-wrap:wrap;">${col(p1,m1)}${col(p2,m2)}</div></div>`;
  document.getElementById('boardView').classList.add('hidden');
  document.getElementById('reportView').classList.remove('hidden');
  window.scrollTo(0,0);
}

/* ══ SEARCH ══ */
function handleSearch(q){searchQuery=q.toLowerCase().trim();renderBoard();}

/* ══ SHAREABLE LINKS ══ */
function copyLink(id){
  const url=window.location.origin+window.location.pathname+'#'+id;
  navigator.clipboard.writeText(url).then(()=>alert('Link copied: '+url));
}

/* ══ SUBSCRIBE ══ */
async function subscribe(){
  const email=document.getElementById('subEmail').value.trim();
  const name=document.getElementById('subName').value.trim();
  if(!email||!email.includes('@')){document.getElementById('subMsg').textContent='Please enter a valid email address.';return;}
  if(!hubSb){document.getElementById('subMsg').textContent='Subscribe feature not yet configured.';return;}
  const{error}=await hubSb.from('subscribers').insert({email,name});
  if(error&&error.code==='23505'){document.getElementById('subMsg').textContent='You are already subscribed.';}
  else if(error){document.getElementById('subMsg').textContent='Something went wrong. Please try again.';}
  else{document.getElementById('subForm').style.display='none';document.getElementById('subMsg').textContent='Subscribed. You will hear from us when the next report drops.';}
}

/* ══ INIT ══ */
renderMast();
renderMainFilters();
renderBoard();
if(window.location.hash){const hid=window.location.hash.replace('#','');const hp=REPORTS.find(r=>r.id===hid);if(hp)showReport(hid,'board');}
</script>
</body>
</html>
